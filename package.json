{
  "name": "clawforge",
  "version": "2.1.0",
  "type": "module",
  "description": "Secure Claude Code agent gateway — multi-channel AI agent with Docker isolation and git-as-audit-trail.",
  "bin": {
    "clawforge": "./bin/cli.js"
  },
  "main": "api/index.js",
  "exports": {
    "./api": "./api/index.js",
    "./config": "./config/index.js",
    "./instrumentation": "./config/instrumentation.js",
    "./auth": "./lib/auth/index.js",
    "./auth/actions": "./lib/auth/actions.js",
    "./chat/api": "./lib/chat/api.js",
    "./chat/terminal-api": "./lib/chat/terminal-api.js",
    "./db": "./lib/db/index.js",
    "./chat": "./lib/chat/components/index.js",
    "./chat/actions": "./lib/chat/actions.js",
    "./db/workspaces": "./lib/db/workspaces.js",
    "./ws/actions": "./lib/ws/actions.js",
    "./middleware": "./lib/auth/middleware.js",
    "./package.json": "./package.json"
  },
  "files": [
    "bin/",
    "lib/",
    "api/",
    "config/",
    "setup/",
    "templates/",
    "drizzle/"
  ],
  "scripts": {
    "build": "esbuild lib/chat/*.jsx lib/chat/components/*.jsx lib/chat/components/**/*.jsx --outdir=lib/chat --format=esm --jsx=automatic --outbase=lib/chat",
    "prepublishOnly": "npm run build",
    "local": "bash bin/local.sh",
    "postinstall": "if [ -f bin/postinstall.js ]; then node bin/postinstall.js; fi",
    "db:generate": "drizzle-kit generate",
    "db:studio": "drizzle-kit studio",
    "test": "echo \"No tests yet\" && exit 0"
  },
  "keywords": [
    "ai",
    "agent",
    "autonomous",
    "telegram",
    "slack",
    "claude-code",
    "nextjs",
    "docker"
  ],
  "author": "Noah Wessel / Scaling Engine",
  "license": "MIT",
  "dependencies": {
    "@ai-sdk/react": "^2.0.0",
    "@anthropic-ai/claude-agent-sdk": "^0.2.77",
    "@clack/prompts": "^0.10.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@grammyjs/parse-mode": "^2.2.0",
    "@langchain/anthropic": "^1.3.17",
    "@langchain/core": "^1.1.24",
    "@langchain/google-genai": "^2.1.18",
    "@langchain/langgraph": "^1.1.4",
    "@langchain/langgraph-checkpoint-sqlite": "^1.0.1",
    "@langchain/openai": "^1.2.7",
    "@sentry/nextjs": "^10.44.0",
    "@slack/bolt": "^4.1.0",
    "@slack/web-api": "^7.8.0",
    "@streamdown/code": "^1.1.0",
    "@tailwindcss/postcss": "^4.2.0",
    "@xterm/addon-attach": "^0.12.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/addon-serialize": "^0.14.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "ai": "^5.0.0",
    "bcrypt-ts": "^6.0.0",
    "better-sqlite3": "^12.6.2",
    "chalk": "^5.3.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.0.0",
    "diff2html": "^3.4.56",
    "dockerode": "^4.0.9",
    "dotenv": "^16.3.1",
    "drizzle-orm": "^0.44.0",
    "grammy": "^1.39.3",
    "lucide-react": "^0.400.0",
    "next-themes": "^0.4.6",
    "node-cron": "^3.0.3",
    "open": "^10.0.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "streamdown": "^2.2.0",
    "tailwind-merge": "^3.0.0",
    "tailwindcss": "^4.2.0",
    "tweetnacl": "^1.0.3",
    "tweetnacl-sealedbox-js": "^1.2.0",
    "uuid": "^9.0.0",
    "ws": "^8.19.0",
    "yaml": "^2.8.2",
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "next": ">=15.5.12",
    "next-auth": "^5.0.0-beta.30",
    "react": ">=19.0.0",
    "react-dom": ">=19.0.0"
  },
  "peerDependenciesMeta": {
    "next-auth": {
      "optional": false
    }
  },
  "devDependencies": {
    "drizzle-kit": "^0.31.9",
    "esbuild": "^0.27.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
