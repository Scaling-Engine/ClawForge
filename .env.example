# ClawForge Multi-Instance Environment Variables
# Copy this file to .env and fill in all values.
# NEVER commit the actual .env file with real secrets!

# ─── Let's Encrypt (shared) ───────────────────────────────────────────
# Uncomment and set to enable automatic TLS in docker-compose.yml
# LETSENCRYPT_EMAIL=

# ═══════════════════════════════════════════════════════════════════════
# NOAH'S INSTANCE — clawforge.scalingengine.com
# ═══════════════════════════════════════════════════════════════════════

# App
NOAH_APP_URL=https://clawforge.scalingengine.com
NOAH_APP_HOSTNAME=clawforge.scalingengine.com

# Auth (generate with: openssl rand -base64 32)
NOAH_AUTH_SECRET=

# GitHub (needs repo, workflow scopes)
NOAH_GH_TOKEN=
# v1.2 Cross-Repo Targeting: Fine-grained PAT must include:
#   - contents:write on all repos in REPOS.json (read/write code on job branches)
#   - pull_requests:write on all repos in REPOS.json (create PRs on target repos)
#   - Current PAT scope: clawforge only. Update in GitHub Settings > Developer Settings > Fine-grained tokens.
NOAH_GH_OWNER=ScalingEngine
NOAH_GH_REPO=clawforge
NOAH_GH_WEBHOOK_SECRET=

# LLM
NOAH_LLM_PROVIDER=anthropic
NOAH_LLM_MODEL=claude-sonnet-4-6
NOAH_ANTHROPIC_API_KEY=

# Slack
NOAH_SLACK_BOT_TOKEN=
NOAH_SLACK_SIGNING_SECRET=
NOAH_SLACK_ALLOWED_USERS=
NOAH_SLACK_ALLOWED_CHANNELS=
NOAH_SLACK_REQUIRE_MENTION=

# Telegram
NOAH_TELEGRAM_BOT_TOKEN=
NOAH_TELEGRAM_WEBHOOK_SECRET=
NOAH_TELEGRAM_CHAT_ID=

# Docker Engine Dispatch (Phase 19)
# Network name for job containers — must match the actual Docker network name.
# Docker Compose prefixes with project name, e.g., clawforge_noah-net
# Discover actual name: docker network ls | grep noah-net
NOAH_DOCKER_NETWORK=noah-net
NOAH_JOB_IMAGE=scalingengine/clawforge:job-latest
# JSON objects of secrets to pass to job containers
# AGENT_SECRETS: non-LLM secrets (GH_TOKEN, etc.) — not visible to Claude Code
# AGENT_LLM_SECRETS: LLM API keys — visible to Claude Code
NOAH_AGENT_SECRETS={"AGENT_GH_TOKEN":"ghp_..."}
NOAH_AGENT_LLM_SECRETS={"AGENT_LLM_ANTHROPIC_API_KEY":"sk-ant-..."}

# ═══════════════════════════════════════════════════════════════════════
# STRATEGYES INSTANCE — strategyES.scalingengine.com
# ═══════════════════════════════════════════════════════════════════════

# App
SES_APP_URL=https://strategyES.scalingengine.com
SES_APP_HOSTNAME=strategyES.scalingengine.com

# Auth (generate with: openssl rand -base64 32)
SES_AUTH_SECRET=

# GitHub (scoped to strategyes-lab ONLY)
SES_GH_TOKEN=
# v1.2 Cross-Repo Targeting: Fine-grained PAT must include:
#   - contents:write on all repos in REPOS.json (read/write code on job branches)
#   - pull_requests:write on all repos in REPOS.json (create PRs on target repos)
#   - Current PAT scope: strategyes-lab only. Update if adding cross-repo targets.
SES_GH_OWNER=ScalingEngine
SES_GH_REPO=strategyes-lab
SES_GH_WEBHOOK_SECRET=

# LLM
SES_LLM_PROVIDER=anthropic
SES_LLM_MODEL=claude-sonnet-4-6
SES_ANTHROPIC_API_KEY=

# Slack (Jim only)
SES_SLACK_BOT_TOKEN=
SES_SLACK_SIGNING_SECRET=
SES_SLACK_ALLOWED_USERS=
SES_SLACK_ALLOWED_CHANNELS=
SES_SLACK_REQUIRE_MENTION=true

# OpenAI (required for Slack audio/voice message transcription via Whisper)
SES_OPENAI_API_KEY=

# Docker Engine Dispatch (Phase 19)
# Network name for job containers — must match the actual Docker network name.
# Docker Compose prefixes with project name, e.g., clawforge_strategyES-net
# Discover actual name: docker network ls | grep strategyES-net
SES_DOCKER_NETWORK=strategyES-net
SES_JOB_IMAGE=scalingengine/clawforge:job-latest
# JSON objects of secrets to pass to job containers
# AGENT_SECRETS: non-LLM secrets (GH_TOKEN, etc.) — not visible to Claude Code
# AGENT_LLM_SECRETS: LLM API keys — visible to Claude Code
SES_AGENT_SECRETS={"AGENT_GH_TOKEN":"ghp_..."}
SES_AGENT_LLM_SECRETS={"AGENT_LLM_ANTHROPIC_API_KEY":"sk-ant-..."}

# ─── Sentry (optional — error capture disabled when not set) ──────────
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
